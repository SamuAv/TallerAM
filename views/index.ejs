<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2">Panel de Citas</h1>
    <a href="/create" class="btn btn-primary">+ Nueva Cita</a>
</div>

<div class="row">
    <% if (appointments.length === 0) { %>
        <div class="col-12 text-center py-5">
            <p class="text-muted">No hay citas programadas.</p>
        </div>
    <% } else { %>
        <% appointments.forEach(app => { %>
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title text-primary">
                                🐾 <%= app.pet_name %>
                                <small class="text-muted fs-6">(<%= app.pet_species %>)</small>
                            </h5>
                            <span class="badge bg-soft-primary text-primary" style="background-color: #e0e0ff;">
                                <%= app.status %>
                            </span>
                        </div>
                        <p class="card-text mb-1"><strong>Dueño:</strong> <%= app.owner_name %></p>
                        <p class="card-text mb-1"><strong>Servicio:</strong> <%= app.service %></p>
                        <p class="card-text mb-3"><strong>Fecha:</strong> <%= app.appointment_date %></p>

                        <% if (app.weight_kg || app.temperature_c || app.diagnosis) { %>
                            <div class="border-top pt-2 mb-3">
                                <p class="text-secondary fw-semibold mb-1" style="font-size:0.85rem;">🩺 Constantes Vitales</p>
                                <% if (app.weight_kg) { %>
                                    <p class="card-text mb-1" style="font-size:0.9rem;">
                                        <strong>Peso:</strong> <%= app.weight_kg %> kg
                                    </p>
                                <% } %>
                                <% if (app.temperature_c) { %>
                                    <p class="card-text mb-1" style="font-size:0.9rem;">
                                        <strong>Temperatura:</strong> <%= app.temperature_c %> °C
                                    </p>
                                <% } %>
                                <% if (app.diagnosis) { %>
                                    <p class="card-text mb-1" style="font-size:0.9rem;">
                                        <strong>Diagnóstico:</strong> <%= app.diagnosis %>
                                    </p>
                                <% } %>
                            </div>
                        <% } %>

                        <% if (locals.user) { %>
                            <form action="/delete/<%= app.id %>" method="POST" class="delete-form">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                            </form>
                        <% } else { %>
                            <p class="text-muted mb-0" style="font-size:0.8rem;">
                                🔒 <a href="/login">Inicia sesión</a> para eliminar
                            </p>
                        <% } %>
                    </div>
                </div>
            </div>
        <% }) %>
    <% } %>
</div>