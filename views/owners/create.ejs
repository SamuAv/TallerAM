<div class="row justify-content-center">
    <div class="col-md-7 col-lg-5">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="card-title text-center mb-4">Registrar Dueño</h2>

                <% if (error) { %>
                    <div class="alert alert-danger mb-3"><%= error %></div>
                <% } %>

                <form action="/owners/create" method="POST">
                    <div class="mb-3">
                        <label for="name" class="form-label">Nombre completo <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="name" name="name" required
                               placeholder="Ej: Carlos Ruiz">
                    </div>
                    <div class="mb-3">
                        <label for="phone" class="form-label">Teléfono</label>
                        <input type="tel" class="form-control" id="phone" name="phone"
                               placeholder="Ej: 555-1234">
                    </div>
                    <div class="mb-4">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" class="form-control" id="email" name="email"
                               placeholder="Ej: carlos@email.com">
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">Guardar Dueño</button>
                        <a href="/owners" class="btn btn-link text-muted">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
