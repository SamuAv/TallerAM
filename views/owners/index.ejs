<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2">Dueños</h1>
    <a href="/owners/create" class="btn btn-primary">+ Nuevo Dueño</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <% if (owners.length === 0) { %>
            <div class="text-center py-5">
                <p class="text-muted mb-3">No hay dueños registrados.</p>
                <a href="/owners/create" class="btn btn-primary">Registrar primer dueño</a>
            </div>
        <% } else { %>
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Nombre</th>
                        <th>Teléfono</th>
                        <th>Email</th>
                        <th>Registrado</th>
                    </tr>
                </thead>
                <tbody>
                    <% owners.forEach(o => { %>
                        <tr>
                            <td class="text-muted"><%= o.id %></td>
                            <td><strong><%= o.name %></strong></td>
                            <td><%= o.phone || '—' %></td>
                            <td><%= o.email || '—' %></td>
                            <td><small class="text-muted"><%= o.created_at %></small></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </div>
</div>
